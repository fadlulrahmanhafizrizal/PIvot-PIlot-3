{
  "type": "AdaptiveCard",
  "body": [
    {
      "type": "TextBlock",
      "size": "Medium",
      "weight": "Bolder",
      "text": "Pivot Pilot Stats"
    },
    {
      "type": "FactSet",
      "facts": [
        {
          "title": "Status:",
          "value": "${status}"
        },
        {
          "title": "Last Update:",
          "value": "${last_update}"
        },
        {
          "title": "Score:",
          "value": "${score}/100"
        }
      ]
    }
  ],
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "version": "1.5"
}